<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Portföyü Düzenle"
        android:textColor="#000000"
        android:textSize="22sp"
        android:textStyle="bold"
        android:padding="20dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Varlıkları sürükleyerek sıralayın veya kaydırarak silin."
        android:textColor="#888888"
        android:textSize="14sp"
        android:paddingHorizontal="20dp"
        android:paddingBottom="10dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEditPortfolio"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="10dp" />

    <Button
        android:id="@+id/btnSavePortfolio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:text="Değişiklikleri Kaydet"
        android:backgroundTint="#0F172A"
        android:textColor="#FFFFFF" />

</LinearLayout>