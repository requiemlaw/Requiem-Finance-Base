<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/detailName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Yükleniyor..."
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/detailPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$0.00"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↗ Canlı Veri Takibi"
                android:textColor="#00D06C"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_centerVertical="true"/>

            <ImageView
                android:id="@+id/btnIndicatorSettings"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:padding="4dp"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="#F0B90B" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/chartPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/transparent"
            android:layout_marginTop="20dp"
            android:paddingBottom="4dp">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:scrollbars="none"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/btnCandle15m"
                        android:layout_width="52dp"
                        android:layout_height="28dp"
                        android:text="15D"
                        android:gravity="center"
                        android:textSize="11sp"
                        android:textColor="#848E9C"
                        android:background="@drawable/btn_interval_bg"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/btnCandle1h"
                        android:layout_width="52dp"
                        android:layout_height="28dp"
                        android:text="1S"
                        android:gravity="center"
                        android:textSize="11sp"
                        android:textColor="#848E9C"
                        android:background="@drawable/btn_interval_bg"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/btnCandle4h"
                        android:layout_width="52dp"
                        android:layout_height="28dp"
                        android:text="4S"
                        android:gravity="center"
                        android:textSize="11sp"
                        android:textColor="#848E9C"
                        android:background="@drawable/btn_interval_bg"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/btnCandle1d"
                        android:layout_width="52dp"
                        android:layout_height="28dp"
                        android:text="1G"
                        android:gravity="center"
                        android:textSize="11sp"
                        android:textColor="#848E9C"
                        android:background="@drawable/btn_interval_bg"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/btnCandle1w"
                        android:layout_width="52dp"
                        android:layout_height="28dp"
                        android:text="1H"
                        android:gravity="center"
                        android:textSize="11sp"
                        android:textColor="#848E9C"
                        android:background="@drawable/btn_interval_bg"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/btnCandle1M"
                        android:layout_width="52dp"
                        android:layout_height="28dp"
                        android:text="1AY"
                        android:gravity="center"
                        android:textSize="11sp"
                        android:textColor="#848E9C"
                        android:background="@drawable/btn_interval_bg"/>

                </LinearLayout>
            </HorizontalScrollView>

            <com.example.rartyfinancebase.CandlestickChartView
                android:id="@+id/candlestickChart"
                android:layout_width="match_parent"
                android:layout_height="340dp"
                android:background="@android:color/transparent"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/statsWrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:background="@android:color/transparent">

            <LinearLayout
                android:id="@+id/statsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:text="İstatistikler"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:text="Gün Aralığı: "
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/tvDayRange"
                        android:text="--"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">
                    <TextView
                        android:text="52 Haftalık: "
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/tvYearRange"
                        android:text="--"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">
                    <TextView
                        android:text="Hacim: "
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/tvVolume"
                        android:text="--"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>